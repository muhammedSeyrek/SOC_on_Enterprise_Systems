<group name="nac_custom_rules">

    <!-- Brute Force -->

    <rule id="100100" level="12">

        <decoded_as>json</decoded_as>

        <field name="event">rate_limit_exceeded</field>

        <description>
            Kritik Ağ İhlali (Brute Force)
        </description>

        <group>
            brute_force,
            authentication_failed,
        </group>

    </rule>



    <!-- Certificate Spoofing -->

    <rule id="100101" level="12">

        <decoded_as>json</decoded_as>

        <field name="event">certificate_spoofing</field>

        <description>
            Certificate Spoofing Attack
        </description>

        <group>
            certificate,
            spoofing,
        </group>

    </rule>



    <!-- Unauthorized Access -->

    <rule id="100102" level="12">

        <decoded_as>json</decoded_as>

        <field name="event">unauthorized_access</field>

        <description>
            Unauthorized Access
        </description>

        <group>
            unauthorized,
            network,
        </group>

    </rule>

</group>