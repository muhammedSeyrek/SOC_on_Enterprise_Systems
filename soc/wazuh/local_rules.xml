<group name="nac_custom_rules">

    <rule id="100100" level="12">
        <field name="event">rate_limit_exceeded</field>
        <description>Kritik Ağ İhlali (Brute Force)</description>
        <group>authentication,bruteforce,</group>
    </rule>

    <rule id="100101" level="10">
        <field name="event">auth_decision</field>
        <field name="result">reject</field>
        <field name="reason">gecersiz_veya_iptal_kimlik</field>

        <description>Certificate Authentication Failed</description>

        <group>certificate,authentication,</group>
    </rule>

    <rule id="100102" level="12">
        <field name="event">unauthorized_access</field>

        <description>Unauthorized Access Attempt</description>

        <group>authentication,network,</group>
    </rule>

</group>