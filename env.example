# ============================================================
#  Bu dosyayı `.env` olarak kopyalayın ve değerleri değiştirin.
#  cp .env.example .env
#  .env dosyasını .gitignore'a ekleyin (repoya PUSH ETMEYİN).
# ============================================================

# --- PostgreSQL ---
POSTGRES_DB=radius
POSTGRES_USER=radius
POSTGRES_PASSWORD=degistir_guclu_bir_sifre

# --- RADIUS ---
RADIUS_CLIENT_SECRET=degistir_radius_secret

# --- Redis ---
REDIS_PASSWORD=degistir_redis_sifresi

# --- Policy Engine / Rate-Limiting ---
# FAIL_WINDOW_SECONDS içinde FAIL_THRESHOLD kadar başarısız deneme
# olursa "kritik" sinyali üretilir (Wazuh alarmını tetikler).
FAIL_THRESHOLD=5
FAIL_WINDOW_SECONDS=60
